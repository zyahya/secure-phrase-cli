<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>sph</ToolCommandName>
    <PackageOutputPath>./nupkg</PackageOutputPath>
    <PackageId>SecurePhrase.Cli</PackageId>
    <Version>0.1.0</Version>
    <Authors>Ziad Yahya</Authors>
    <Description>A fast, offline passphrase generator for the terminal.</Description>

    <RepositoryUrl>https://github.com/zyahaya/secure-phrase-cli</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SecurePhrase" Version="0.1.0" />
  </ItemGroup>

</Project>
